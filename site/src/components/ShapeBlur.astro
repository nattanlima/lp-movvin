---
/* ============================================================================
 * SHAPE BLUR · contorno que acende sob o cursor
 * ----------------------------------------------------------------------------
 * Inspirado no ShapeBlur do reactbits.dev, mas a MATEMATICA DA FORMA foi
 * reescrita. O porte verbatim nao servia, e vale registrar por que:
 *
 * O shader original normaliza as coordenadas pelo lado MENOR do container
 * (funcao coord()), o que torna a forma um QUADRADO no espaco normalizado.
 * Isso funciona no demo deles, que e um quadrado com uma forma decorativa
 * flutuando no meio. Num cartao 203x164 o eixo X passa a ir de -0,119 a 1,119
 * enquanto o Y vai de 0 a 1: a borda de cima e a de baixo caem na aresta, e as
 * laterais param a ~81% da meia-largura, PARA DENTRO. Era o defeito visivel.
 *
 * Aqui o SDF e um sdRoundBox em espaco de PIXELS, com meia-extensao derivada
 * da resolucao real. Consequencias: o contorno traca a aresta do cartao em
 * qualquer proporcao, a espessura e uniforme nos 4 lados, e o raio dos cantos
 * casa com o border-radius do CSS.
 *
 * O brilho vaza PARA FORA e para dentro: e a soma de um traco nitido com um
 * halo exponencial simetrico. Pra isso o canvas e MAIOR que o cartao
 * (--mv-sangria) e ninguem pode ter overflow:hidden no caminho.
 *
 * WebGL1 de proposito: sem dFdx (o AA agora vem do smoothstep em px, que e
 * exato porque o SDF ja esta em pixels), entao nem extensao e preciso.
 * ========================================================================== */

interface Props {
  class?: string;
  /** Quantos px o canvas extrapola o cartao em cada lado. E o espaco que o brilho tem pra vazar. */
  sangria?: number;
  /** Raio dos cantos, em px. Casar com o border-radius do elemento. */
  raio?: number;
  /** Espessura do traco nitido, em px. */
  espessura?: number;
  /** Alcance do halo, em px. Quanto maior, mais difuso. */
  halo?: number;
  /** Raio do circulo que revela o contorno, em px. */
  alcance?: number;
  /** Intensidade final (0 a 1). */
  intensidade?: number;
  color?: [number, number, number];
}

const {
  class: klass = '',
  sangria = 44,
  raio = 16,
  espessura = 1.5,
  halo = 26,
  alcance = 150,
  intensidade = 1,
  color = [0.784, 0.945, 0.247], // #C8F13F
} = Astro.props;

const cfg = JSON.stringify({ sangria, raio, espessura, halo, alcance, intensidade, color });
---

<div
  class={`mv-shapeblur ${klass}`}
  data-mv-shapeblur
  data-cfg={cfg}
  aria-hidden="true"
  style={`inset: -${sangria}px;`}
>
</div>

<style>
  .mv-shapeblur {
    position: absolute;
    pointer-events: none;
    /* SEM overflow:hidden. Era o que cortava o brilho na aresta. */
  }
  .mv-shapeblur :global(canvas) {
    display: block;
    width: 100%;
    height: 100%;
    opacity: 0;
    transition: opacity 700ms var(--ease-mv);
  }
  .mv-shapeblur :global(canvas[data-pronto]) {
    opacity: 1;
  }
</style>

<script>
  const VERT = `attribute vec2 aPos;
void main() { gl_Position = vec4(aPos, 0.0, 1.0); }`;

  const FRAG = `precision highp float;

uniform vec2 u_resolution;   // px do canvas (ja com DPR)
uniform vec2 u_mouse;        // px, mesmo espaco
uniform float u_sangria;     // px que o canvas passa do cartao, por lado
uniform float u_raio;        // raio dos cantos, px
uniform float u_espessura;   // traco nitido, px
uniform float u_halo;        // alcance do halo, px
uniform float u_alcance;     // raio do circulo revelador, px
uniform float u_intensidade;
uniform vec3 u_color;

/* SDF exato de retangulo arredondado, em pixels: distancia assinada da
   aresta. Negativo dentro, positivo fora. Isto e o que o coord() do original
   nao dava, porque la a forma era sempre quadrada. */
float sdRoundBox(vec2 p, vec2 b, float r) {
  vec2 q = abs(p) - b + r;
  return min(max(q.x, q.y), 0.0) + length(max(q, 0.0)) - r;
}

void main() {
  vec2 centro = 0.5 * u_resolution;
  vec2 p = gl_FragCoord.xy - centro;

  // A meia-extensao do CARTAO: o canvas e maior que ele pela sangria.
  vec2 b = centro - vec2(u_sangria);
  float d = sdRoundBox(p, b, u_raio);
  float ad = abs(d);

  // Traco nitido em cima da aresta.
  float traco = 1.0 - smoothstep(u_espessura, u_espessura + 1.5, ad);

  /* Halo simetrico: vaza pros DOIS lados da aresta, inclusive pra fora.
     A JANELA nao e enfeite. exp() nunca chega a zero: com halo=22 e
     sangria=48, na fronteira do canvas o alpha ainda valia exp(-48/22)*0.55
     = 0,062. Como o canvas acaba ali, esses 6% eram cortados numa linha reta
     e desenhavam um RETANGULO VERDE FANTASMA em volta do cartao (degrau
     medido de G=10 pra G=25 em 1px). A janela leva o halo a zero ANTES da
     borda, entao nao ha o que cortar. */
  float janela = 1.0 - smoothstep(u_sangria * 0.5, u_sangria * 0.94, ad);
  float halo = exp(-ad / max(u_halo, 1.0)) * 0.55 * janela;

  // O circulo que segue o cursor revela o contorno.
  float dm = length(p - (u_mouse - centro));
  float rev = 1.0 - smoothstep(u_alcance * 0.35, u_alcance, dm);

  /* Combinacao tipo "screen", nao soma. Somar dava pico de 1,55 e o clamp
     cortava em 1,0, achatando a rampa de antialias: o traco de 1,5px virava
     um plato de 4,5px com a borda dura, o que lia como neon generico em vez
     de aresta acesa. Assim o teto e 1,0 por construcao e o AA sobrevive. */
  float a = (traco + (1.0 - traco) * halo) * rev * u_intensidade;
  gl_FragColor = vec4(u_color, a);
}`;

  function compilar(gl: WebGLRenderingContext, tipo: number, src: string) {
    const s = gl.createShader(tipo)!;
    gl.shaderSource(s, src);
    gl.compileShader(s);
    if (!gl.getShaderParameter(s, gl.COMPILE_STATUS)) {
      gl.deleteShader(s);
      return null;
    }
    return s;
  }

  function iniciar(host: HTMLElement) {
    const cfg = JSON.parse(host.dataset.cfg || '{}');
    const canvas = document.createElement('canvas');
    /* premultipliedAlpha:false explicito. O default do spec e TRUE, e o
       shader emite alpha NAO premultiplicado (vec4(cor, a) com a cor cheia).
       Com o default o compositor eleva o alpha ao quadrado e o halo sai
       aditivo/lavado. No hero quase preto isso passa despercebido, mas
       estoura em qualquer superficie clara: e bug latente, nao teorico. */
    const gl = canvas.getContext('webgl', {
      alpha: true,
      antialias: false,
      premultipliedAlpha: false,
    });
    if (!gl) return;

    const vs = compilar(gl, gl.VERTEX_SHADER, VERT);
    const fs = compilar(gl, gl.FRAGMENT_SHADER, FRAG);
    if (!vs || !fs) return;

    const prog = gl.createProgram()!;
    gl.attachShader(prog, vs);
    gl.attachShader(prog, fs);
    gl.linkProgram(prog);
    if (!gl.getProgramParameter(prog, gl.LINK_STATUS)) return;
    gl.useProgram(prog);
    host.appendChild(canvas);

    const buf = gl.createBuffer();
    gl.bindBuffer(gl.ARRAY_BUFFER, buf);
    gl.bufferData(gl.ARRAY_BUFFER, new Float32Array([-1, -1, 3, -1, -1, 3]), gl.STATIC_DRAW);
    const aPos = gl.getAttribLocation(prog, 'aPos');
    gl.enableVertexAttribArray(aPos);
    gl.vertexAttribPointer(aPos, 2, gl.FLOAT, false, 0, 0);

    gl.enable(gl.BLEND);
    gl.blendFunc(gl.SRC_ALPHA, gl.ONE_MINUS_SRC_ALPHA);

    const u = (n: string) => gl.getUniformLocation(prog, n);
    const U = {
      res: u('u_resolution'), mouse: u('u_mouse'), sangria: u('u_sangria'),
      raio: u('u_raio'), esp: u('u_espessura'), halo: u('u_halo'),
      alc: u('u_alcance'), inten: u('u_intensidade'), color: u('u_color'),
    };
    gl.uniform3fv(U.color, cfg.color ?? [1, 1, 1]);
    gl.uniform1f(U.inten, cfg.intensidade ?? 1);

    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    const medir = () => {
      const w = Math.max(host.clientWidth, 1);
      const h = Math.max(host.clientHeight, 1);
      canvas.width = Math.round(w * dpr);
      canvas.height = Math.round(h * dpr);
      gl.viewport(0, 0, canvas.width, canvas.height);
      // Tudo em px de canvas: o DPR entra uma vez so, aqui.
      gl.uniform2f(U.res, canvas.width, canvas.height);
      gl.uniform1f(U.sangria, (cfg.sangria ?? 44) * dpr);
      gl.uniform1f(U.raio, (cfg.raio ?? 16) * dpr);
      gl.uniform1f(U.esp, (cfg.espessura ?? 1.5) * dpr);
      gl.uniform1f(U.halo, (cfg.halo ?? 26) * dpr);
      gl.uniform1f(U.alc, (cfg.alcance ?? 150) * dpr);
    };
    medir();
    new ResizeObserver(medir).observe(host);

    /* O ponteiro fica em coordenadas de VIEWPORT, e a conversao pro espaco do
       canvas acontece no rAF. Antes o getBoundingClientRect era lido dentro do
       handler de pointermove e o resultado ja virava coordenada local: como o
       cartao anda na tela ao rolar, quem rolava sem mexer o mouse via o brilho
       descolar do cursor na mesma medida do scroll. Ler o rect no frame corrige
       isso E tira o reflow sincrono do handler, que dispara a ~120Hz. */
    let clienteX = -99999, clienteY = -99999;
    let x = -99999, y = -99999;
    let ativo = false;
    let raf = 0;
    let ultimo = performance.now();

    document.addEventListener(
      'pointermove',
      (e) => {
        clienteX = e.clientX;
        clienteY = e.clientY;
      },
      { passive: true },
    );

    const damp = (a: number, b: number, lambda: number, dt: number) =>
      a + (b - a) * (1 - Math.exp(-lambda * dt));

    const desenhar = (t: number) => {
      raf = requestAnimationFrame(desenhar);
      const dt = Math.min((t - ultimo) * 0.001, 0.064);
      ultimo = t;
      const r = host.getBoundingClientRect();
      // Y invertido: gl_FragCoord conta de baixo pra cima.
      const alvoX = (clienteX - r.left) * dpr;
      const alvoY = (r.bottom - clienteY) * dpr;
      x = damp(x, alvoX, 9, dt);
      y = damp(y, alvoY, 9, dt);
      gl.uniform2f(U.mouse, x, y);
      gl.drawArrays(gl.TRIANGLES, 0, 3);
    };

    new IntersectionObserver(
      ([e]) => {
        if (e.isIntersecting && !ativo) {
          ativo = true;
          ultimo = performance.now();
          raf = requestAnimationFrame(desenhar);
          canvas.setAttribute('data-pronto', '');
        } else if (!e.isIntersecting && ativo) {
          ativo = false;
          cancelAnimationFrame(raf);
        }
      },
      { threshold: 0 },
    ).observe(host);
  }

  /* INICIALIZACAO PREGUICOSA.
     Antes o iniciar() rodava na carga pra todo host. No celular o cartao e
     `hidden sm:block`, entao o host ficava display:none: o contexto WebGL era
     criado, os shaders compilados e o programa linkado pra um canvas 1x1 que
     nunca desenhava um frame. Desperdicio 100% sem beneficio.
     Um IntersectionObserver nao dispara em elemento sem caixa, entao usar ele
     como gatilho resolve os dois casos de uma vez: no celular nunca inicia, e
     se a janela for alargada alem do sm o cartao ganha caixa, o observer
     dispara e o efeito nasce ali. */
  const redMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
  document.querySelectorAll<HTMLElement>('[data-mv-shapeblur]').forEach((el) => {
    if (redMotion.matches) return;
    const io = new IntersectionObserver(([e]) => {
      if (!e.isIntersecting) return;
      io.disconnect();
      iniciar(el);
    });
    io.observe(el);
  });
</script>
